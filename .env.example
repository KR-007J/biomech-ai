# ============================================
# Biomech AI Backend Configuration
# ============================================

# Core APIs
GEMINI_API_KEY=your_gemini_api_key_here
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Security (Phase 2.1-2.3)
API_KEY_SECRET=your_secret_key_for_api_signing_min_32_chars_long
JWT_SECRET=your_jwt_secret_key_min_32_chars_long

# CORS Configuration (Phase 1.1 - Security)
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8000

# For production, use your actual domain:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# ============================================
# Performance & Caching (Phase 2.5-2.8)
# ============================================

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Async Tasks (Phase 2.6)
TASK_WORKERS=4

# ============================================
# Monitoring & Error Tracking (Phase 2.9-2.10)
# ============================================

# Sentry Error Tracking (Phase 2.9)
SENTRY_DSN=your_sentry_dsn_here

# Prometheus Metrics (Phase 2.10)
PROMETHEUS_PUSH_GATEWAY=localhost:9091

# ============================================
# Enterprise Features (Phase 5)
# ============================================

# Multi-Tenancy (Phase 5.1)
ENABLE_MULTI_TENANCY=true
MAX_ORGANIZATIONS=100

# Webhook Integration (Phase 5.3)
WEBHOOK_SECRET=your_webhook_secret_key
STRIPE_API_KEY=your_stripe_api_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
SLACK_BOT_TOKEN=your_slack_bot_token

# ============================================
# Database (Phase 2.4)
# ============================================

# PostgreSQL (if using direct connection)
DATABASE_URL=postgresql://user:password@localhost:5432/biomech_ai

# ============================================
# Development Settings
# ============================================

# File Upload
MAX_UPLOAD_SIZE_MB=100
TEMP_DIR=/tmp/biomech

# Debugging
DEBUG=false
VERBOSE_LOGGING=false
